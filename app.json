{
  "expo": {
    "name": "WarmiNet",
    "slug": "warminet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo/logo_warminet.png",
      "resizeMode": "contain",
      "backgroundColor": "#4b135f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.warminet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4b135f"
      },
      "package": "com.warminet.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE"
      ]
    },
    "platforms": [
      "android",
      "ios"
    ],
    "plugins": [
      "expo-camera",
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "2193bff3-8ac7-4a32-b813-c02b5da7d199"
      }
    }
  }
}
