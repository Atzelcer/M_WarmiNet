# Configuración de variables de entorno para WarmiNet

# Google Maps API Key (REQUERIDO para mapas)
# Obtener en: https://developers.google.com/maps/documentation/android-sdk/get-api-key
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# AWS Configuration (OPCIONAL - solo si usas servicios reales)
AWS_REGION=us-east-1
AWS_USER_POOL_ID=your_user_pool_id
AWS_USER_POOL_CLIENT_ID=your_client_id
AWS_API_GATEWAY_URL=https://your-api-gateway-url.com

# Expo Configuration (OPCIONAL)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Build Configuration
ANDROID_PACKAGE_NAME=com.warminet.app
IOS_BUNDLE_IDENTIFIER=com.warminet.app

# Notas:
# - Este archivo NO debe ser commiteado a Git
# - Copia este archivo como .env y completa con tus valores
# - Para producción, usar secrets management (ej: AWS Secrets Manager)
